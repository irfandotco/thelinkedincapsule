<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>The LinkedIn Capsule</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --black: #0a0a0a;
      --black-soft: #111111;
      --black-mid: #1a1a1a;
      --border: #222;
      --white: #f8f8f8;
      --white-dim: #aaaaaa;
      --white-faint: #555;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Outfit', sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 1.4rem 6vw;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(10,10,10,0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .brand {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: 1px;
      color: var(--white);
      text-decoration: none;
    }

    .nav-btn {
      background: var(--white);
      color: var(--black);
      padding: 0.55rem 1.4rem;
      border-radius: 3px;
      font-size: 0.8rem;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: 0.5px;
      transition: opacity 0.2s;
    }
    .nav-btn:hover { opacity: 0.8; }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column; justify-content: center;
      padding: 10rem 6vw 6rem;
      position: relative;
      border-bottom: 1px solid var(--border);
    }

    .hero-tag {
      font-size: 0.7rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--white-dim);
      margin-bottom: 2rem;
      opacity: 0;
      animation: fadeUp 0.7s 0.2s forwards;
    }

    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3.5rem, 8vw, 8rem);
      font-weight: 700;
      line-height: 1;
      letter-spacing: -2px;
      max-width: 900px;
      opacity: 0;
      animation: fadeUp 0.7s 0.4s forwards;
    }

    .hero h1 em {
      font-style: italic;
      font-weight: 400;
    }

    .hero-divider {
      width: 60px; height: 1px;
      background: var(--white-dim);
      margin: 2.5rem 0;
      opacity: 0;
      animation: fadeUp 0.7s 0.6s forwards;
    }

    .hero-sub {
      font-size: clamp(1rem, 1.5vw, 1.15rem);
      color: var(--white-dim);
      max-width: 520px;
      line-height: 1.8;
      opacity: 0;
      animation: fadeUp 0.7s 0.7s forwards;
    }

    .hero-actions {
      margin-top: 3rem;
      display: flex; gap: 1rem; align-items: center;
      opacity: 0;
      animation: fadeUp 0.7s 0.9s forwards;
    }

    .btn-main {
      background: var(--white);
      color: var(--black);
      padding: 1rem 2.5rem;
      border-radius: 3px;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: 0.5px;
      transition: opacity 0.2s, transform 0.2s;
    }
    .btn-main:hover { opacity: 0.88; transform: translateY(-2px); }

    .price-tag {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.5rem;
      font-weight: 600;
      color: var(--white-dim);
    }
    .price-tag span {
      color: var(--white);
    }

    /* THEORY */
    .theory {
      padding: 8rem 6vw;
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 5rem;
      align-items: start;
    }

    .section-label {
      font-size: 0.7rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--white-faint);
      padding-top: 0.4rem;
    }

    .theory-content h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -1px;
      margin-bottom: 2rem;
    }

    .theory-content h2 em { font-style: italic; font-weight: 400; }

    .theory-content p {
      color: var(--white-dim);
      font-size: 0.95rem;
      line-height: 1.9;
      margin-bottom: 1.2rem;
      max-width: 600px;
    }

    .theory-pills {
      margin-top: 2.5rem;
      display: flex; flex-wrap: wrap; gap: 0.75rem;
    }

    .pill {
      border: 1px solid var(--border);
      padding: 0.5rem 1.1rem;
      border-radius: 100px;
      font-size: 0.8rem;
      color: var(--white-dim);
      letter-spacing: 0.5px;
    }

    /* WHAT YOU LEARN */
    .learn {
      padding: 8rem 6vw;
      border-bottom: 1px solid var(--border);
    }

    .learn-header {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 5rem;
      margin-bottom: 5rem;
      align-items: end;
    }

    .learn h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -1px;
    }

    .learn-intro {
      color: var(--white-dim);
      font-size: 0.95rem;
      line-height: 1.8;
    }

    .learn-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .learn-item {
      background: var(--black-soft);
      padding: 2.5rem;
      position: relative;
      transition: background 0.3s;
    }
    .learn-item:hover { background: var(--black-mid); }

    .learn-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 3.5rem;
      font-weight: 700;
      color: var(--border);
      line-height: 1;
      margin-bottom: 1.5rem;
    }

    .learn-item h3 {
      font-size: 1rem;
      font-weight: 500;
      margin-bottom: 0.75rem;
      line-height: 1.4;
    }

    .learn-item p {
      font-size: 0.85rem;
      color: var(--white-dim);
      line-height: 1.7;
    }

    /* TESTIMONIALS */
    .testimonials {
      padding: 8rem 6vw;
      border-bottom: 1px solid var(--border);
    }

    .test-header {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 5rem;
      margin-bottom: 5rem;
      align-items: end;
    }

    .test-header h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 3.5vw, 3.2rem);
      font-weight: 700;
      letter-spacing: -1px;
      line-height: 1.1;
    }

    .test-header p {
      color: var(--white-dim);
      font-size: 0.95rem;
      line-height: 1.8;
    }

    .test-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .test-card {
      background: var(--black-soft);
      padding: 2.5rem;
    }

    .test-quote {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem;
      font-weight: 400;
      font-style: italic;
      line-height: 1.6;
      margin-bottom: 2rem;
      color: var(--white);
    }

    .test-author {
      display: flex; align-items: center; gap: 1rem;
    }

    .test-avatar {
      width: 38px; height: 38px;
      background: var(--border);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--white-dim);
    }

    .test-name {
      font-size: 0.85rem;
      font-weight: 500;
    }
    .test-role {
      font-size: 0.75rem;
      color: var(--white-faint);
      margin-top: 0.2rem;
    }

    /* PRICING */
    .pricing {
      padding: 8rem 6vw;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
      border-bottom: 1px solid var(--border);
    }

    .pricing-left h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.5rem, 4vw, 4rem);
      font-weight: 700;
      line-height: 1.05;
      letter-spacing: -1px;
      margin-bottom: 1.5rem;
    }

    .pricing-left h2 em { font-style: italic; font-weight: 400; }

    .pricing-left p {
      color: var(--white-dim);
      font-size: 0.95rem;
      line-height: 1.8;
    }

    .pricing-card {
      border: 1px solid var(--border);
      padding: 3rem;
      position: relative;
      overflow: hidden;
    }

    .pricing-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--white);
    }

    .pricing-name {
      font-size: 0.7rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--white-faint);
      margin-bottom: 1.5rem;
    }

    .pricing-amount {
      font-family: 'Cormorant Garamond', serif;
      font-size: 5rem;
      font-weight: 700;
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .pricing-currency {
      font-size: 1.8rem;
      vertical-align: super;
      font-weight: 400;
    }

    .pricing-desc {
      color: var(--white-dim);
      font-size: 0.85rem;
      margin-bottom: 2.5rem;
      line-height: 1.6;
    }

    .pricing-features {
      list-style: none;
      margin-bottom: 2.5rem;
      display: flex; flex-direction: column; gap: 0.9rem;
    }

    .pricing-features li {
      font-size: 0.875rem;
      color: var(--white-dim);
      display: flex; align-items: center; gap: 0.75rem;
    }

    .pricing-features li::before {
      content: '—';
      color: var(--white-faint);
      flex-shrink: 0;
    }

    .btn-buy {
      width: 100%;
      display: block;
      text-align: center;
      background: var(--white);
      color: var(--black);
      padding: 1.1rem;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: none;
      letter-spacing: 0.5px;
      border-radius: 3px;
      transition: opacity 0.2s;
    }
    .btn-buy:hover { opacity: 0.85; }
    .btn-buy { border: none; cursor: pointer; }

    /* FOOTER */
    footer {
      padding: 2.5rem 6vw;
      display: flex; align-items: center; justify-content: space-between;
      border-top: 1px solid var(--border);
      font-size: 0.8rem;
      color: var(--white-faint);
    }

    footer .brand-foot {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1rem;
      font-weight: 600;
      color: var(--white-dim);
    }

    /* ANIMATIONS */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
      .theory, .learn-header, .test-header, .pricing { grid-template-columns: 1fr; gap: 2rem; }
      .hero h1 { letter-spacing: -1px; }
      footer { flex-direction: column; gap: 1rem; text-align: center; }
    }
  </style>
</head>
